<Page
    x:Class="AllLive.UWP.Views.FavoritePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Windows10version1809="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 7)"
    xmlns:controls="using:AllLive.UWP.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AllLive.UWP.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AllLive.UWP.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock FontSize="24">我的关注</TextBlock>
                <ToggleSwitch
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    IsOn="{x:Bind Path=favoriteVM.HideOffline, Mode=TwoWay}"
                    OffContent="显示全部"
                    OnContent="隐藏未开播" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Command="{x:Bind Path=favoriteVM.RefreshCommand}" Visibility="{x:Bind Path=favoriteVM.LoaddingLiveStatus, Mode=OneWay, Converter={StaticResource displayConvert}}">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon
                            FontFamily="{StaticResource SegoeFluent}"
                            FontSize="14"
                            Glyph="&#xE72C;" />
                        <TextBlock Margin="8,0,0,0">刷新列表</TextBlock>
                    </StackPanel>
                </Button>
                <Button Margin="8,0" Command="{x:Bind Path=favoriteVM.InputCommand}">导入列表</Button>
                <Button Command="{x:Bind Path=favoriteVM.OutputCommand}">导出列表</Button>
                <HyperlinkButton
                    Margin="8,0,0,0"
                    VerticalContentAlignment="Center"
                    Command="{x:Bind Path=favoriteVM.TipCommand}">
                    <FontIcon
                        FontFamily="{StaticResource SegoeFluent}"
                        FontSize="16"
                        Glyph="&#xE783;" />
                </HyperlinkButton>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <controls:MyAdaptiveGridView
                Margin="8,0,8,8"
                CanLoadMore="False"
                DesiredWidth="400"
                IsItemClickEnabled="True"
                ItemClick="ls_ItemClick"
                ItemHeight="72"
                ItemsSource="{x:Bind Path=favoriteVM.DisplayItems, Mode=OneWay}"
                SelectionMode="None"
                StretchContentForSingleRow="False">
                <controls:MyAdaptiveGridView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource GridViewItemCornerRadiusStyle}" TargetType="GridViewItem">
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                        <Setter Property="Background" Value="{ThemeResource ButtonBackground}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />

                    </Style>
                </controls:MyAdaptiveGridView.ItemContainerStyle>
                <controls:MyAdaptiveGridView.ItemTemplate>
                    <DataTemplate x:DataType="models:FavoriteItem">
                        <Grid>
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem
                                        Click="MenuFlyoutItem_Click"
                                        Icon="Delete"
                                        Text="移除" />
                                    <MenuFlyoutItem
                                        Click="MenuFlyoutItem_Sort_Click"
                                        Icon="Sort"
                                        Text="排序" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <PersonPicture
                                Width="56"
                                Height="48"
                                Background="Blue"
                                BorderThickness="0"
                                Opacity="{Binding Opacity, Source={StaticResource ImageDimState}}"
                                ProfilePicture="{x:Bind Path=Photo}" />
                            <Grid
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{x:Bind Path=UserName}"
                                    FontWeight="SemiBold"
                                    Margin="0,0,8,0"
                                    TextTrimming="CharacterEllipsis" />
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Ellipse
                                        Width="8"
                                        Height="8"
                                        Margin="0,0,4,0"
                                        VerticalAlignment="Center"
                                        Fill="Green"
                                        Visibility="{x:Bind Path=LiveStatus, Mode=OneWay}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="Gray"
                                        Text="{x:Bind Path=SiteShortName}"
                                        TextAlignment="Right"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Margin="0,4,0,0"
                                    FontSize="12"
                                    Text="{x:Bind Path=LiveTitle}"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{x:Bind Path=HasLiveTitle, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </controls:MyAdaptiveGridView.ItemTemplate>
            </controls:MyAdaptiveGridView>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="Gray"
                Visibility="{x:Bind Path=favoriteVM.IsEmpty, Mode=OneWay}">
                这里还什么都没有~
            </TextBlock>
            <Button
                Width="48"
                Height="48"
                Margin="12"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Windows10version1809:CornerRadius="24"
                Command="{x:Bind Path=favoriteVM.RefreshCommand}"
                Visibility="{x:Bind Path=favoriteVM.LoaddingLiveStatus, Mode=OneWay, Converter={StaticResource displayConvert}}">

                <FontIcon FontFamily="{StaticResource SegoeFluent}" Glyph="&#xE72C;" />

            </Button>
            <Border
                Width="48"
                Height="48"
                Margin="12"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="{ThemeResource ButtonBackground}"
                CornerRadius="24"
                Visibility="{x:Bind Path=favoriteVM.LoaddingLiveStatus, Mode=OneWay}">
                <ProgressRing Width="24" IsActive="True" />
            </Border>
        </Grid>
    </Grid>
</Page>
